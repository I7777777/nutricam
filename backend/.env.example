# NutriCam 后端服务配置

# 服务器配置
PORT=3000
NODE_ENV=development

# 安全
ALLOWED_ORIGINS=http://localhost:3000,https://nutricam.example.com

# OpenAI API (用于食物识别)
OPENAI_API_KEY=your_openai_api_key_here

# Google Vision API (备选识别方案)
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# USDA FoodData Central API (营养数据库)
USDA_API_KEY=your_usda_api_key_here

# 文件上传配置
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=uploads

# 缓存配置 (Redis可选)
REDIS_URL=redis://localhost:6379

# 日志级别
LOG_LEVEL=info